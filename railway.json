{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "Postgres",
      "plugin": "postgresql"
    },
    {
      "name": "Redis",
      "plugin": "redis"
    },
    {
      "name": "backend",
      "root": "backend",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      },
      "variables": {
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}",
        "REDIS_URL": "${{Redis.REDIS_URL}}",
        "JWT_SECRET": "${{secret(64, \"abcdef0123456789\")}}",
        "ADMIN_EMAIL": {
          "description": "Email for admin dashboard login",
          "default": "admin@example.com"
        },
        "ADMIN_PASSWORD": "${{secret(16)}}",
        "NODE_ENV": {
          "description": "Node environment",
          "default": "production"
        },
        "PORT": {
          "description": "Port the backend listens on",
          "default": "3000"
        },
        "PUBLIC_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "TWILIO_ACCOUNT_SID": {
          "description": "Twilio Account SID (optional \u2014 can also be configured via the in-app Settings wizard after deploy)"
        },
        "TWILIO_AUTH_TOKEN": {
          "description": "Twilio Auth Token (optional \u2014 can also be configured via the in-app Settings wizard after deploy)"
        },
        "TWILIO_WHATSAPP_NUMBER": {
          "description": "Twilio WhatsApp sender number in format whatsapp:+1234567890 (optional \u2014 configurable in-app)"
        }
      }
    },
    {
      "name": "dashboard",
      "root": "dashboard",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      },
      "variables": {
        "VITE_API_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}/api/v1"
      }
    }
  ]
}