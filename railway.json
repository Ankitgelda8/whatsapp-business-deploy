{
  "$schema": "https://railway.app/railway.schema.json",
  "services": [
    {
      "name": "Postgres",
      "source": {
        "image": "ghcr.io/railwayapp-templates/postgres-ssl:18"
      },
      "deploy": {
        "requiredMountPath": "/var/lib/postgresql/data"
      },
      "variables": {
        "PGDATA": "/var/lib/postgresql/data/pgdata",
        "PGHOST": "${{RAILWAY_PRIVATE_DOMAIN}}",
        "PGPORT": "5432",
        "PGUSER": "${{POSTGRES_USER}}",
        "PGDATABASE": "${{POSTGRES_DB}}",
        "PGPASSWORD": "${{POSTGRES_PASSWORD}}",
        "POSTGRES_DB": "railway",
        "DATABASE_URL": "postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_PRIVATE_DOMAIN}}:5432/${{PGDATABASE}}",
        "POSTGRES_USER": "postgres",
        "SSL_CERT_DAYS": "820",
        "POSTGRES_PASSWORD": "${{secret(32)}}",
        "DATABASE_PUBLIC_URL": "postgresql://${{PGUSER}}:${{POSTGRES_PASSWORD}}@${{RAILWAY_TCP_PROXY_DOMAIN}}:${{RAILWAY_TCP_PROXY_PORT}}/${{PGDATABASE}}",
        "RAILWAY_DEPLOYMENT_DRAINING_SECONDS": "60"
      },
      "volumes": [
        {
          "mountPath": "/var/lib/postgresql/data"
        }
      ]
    },
    {
      "name": "Redis",
      "source": {
        "image": "redis:8.2.1"
      },
      "deploy": {
        "startCommand": "/bin/sh -c \"rm -rf $RAILWAY_VOLUME_MOUNT_PATH/lost+found/ && exec docker-entrypoint.sh redis-server --requirepass $REDIS_PASSWORD --save 60 1 --dir $RAILWAY_VOLUME_MOUNT_PATH\""
      },
      "variables": {
        "REDISHOST": "${{RAILWAY_PRIVATE_DOMAIN}}",
        "REDISPORT": "6379",
        "REDISUSER": "default",
        "REDIS_PASSWORD": "${{secret(32)}}",
        "REDIS_URL": "redis://${{REDISUSER}}:${{REDIS_PASSWORD}}@${{REDISHOST}}:${{REDISPORT}}",
        "REDIS_PUBLIC_URL": "redis://default:${{REDIS_PASSWORD}}@${{RAILWAY_TCP_PROXY_DOMAIN}}:${{RAILWAY_TCP_PROXY_PORT}}"
      },
      "volumes": [
        {
          "mountPath": "/data"
        }
      ]
    },
    {
      "name": "backend",
      "root": "backend",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      },
      "deploy": {
        "healthcheckPath": "/health",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "networking": {
        "serviceDomains": {
          "<hasDomain>": {}
        }
      },
      "variables": {
        "DATABASE_URL": "${{Postgres.DATABASE_URL}}",
        "REDIS_URL": "${{Redis.REDIS_URL}}",
        "JWT_SECRET": "${{secret(64, \"abcdef0123456789\")}}",
        "ADMIN_EMAIL": {
          "description": "Your dashboard login email",
          "default": "admin@example.com"
        },
        "ADMIN_PASSWORD": {
          "description": "Dashboard login password (auto-generated secure value)",
          "default": "${{secret(16)}}"
        },
        "NODE_ENV": "production",
        "PORT": "3000",
        "PUBLIC_URL": "https://${{RAILWAY_PUBLIC_DOMAIN}}",
        "RAILWAY_HEALTHCHECK_TIMEOUT_SEC": "300",
        "TWILIO_ACCOUNT_SID": {
          "description": "Optional — configure Twilio in-app via Settings wizard after deploy",
          "default": ""
        },
        "TWILIO_AUTH_TOKEN": {
          "description": "Optional — configure Twilio in-app via Settings wizard after deploy",
          "default": ""
        },
        "TWILIO_WHATSAPP_NUMBER": {
          "description": "Optional — e.g. whatsapp:+14155238886 (configurable in-app)",
          "default": ""
        },
        "GROK_API_KEY": {
          "description": "Optional — xAI Grok for AI replies and quote bot (console.x.ai)",
          "default": ""
        },
        "OPENAI_API_KEY": {
          "description": "Optional — OpenAI for embeddings (platform.openai.com)",
          "default": ""
        },
        "RESEND_API_KEY": {
          "description": "Optional — Resend for email fallback (resend.com)",
          "default": ""
        },
        "GOOGLE_MAPS_API_KEY": {
          "description": "Optional — Google Maps for Auto Quote Bot (cab/rental)",
          "default": ""
        },
        "BUSINESS_NAME": {
          "description": "Business name shown in dashboard and messages",
          "default": "My Business"
        },
        "BUSINESS_PHONE": {
          "description": "Owner phone for quote-bot handoff e.g. +919175623369",
          "default": ""
        },
        "BUSINESS_CONTACT_NAME": {
          "description": "Owner name shown in quote-bot messages",
          "default": ""
        },
        "MESSAGE_RETENTION_DAYS": {
          "description": "Auto-delete messages older than N days (0 = off)",
          "default": "15"
        },
        "FEATURE_CAMPAIGN_SCHEDULER": {
          "default": "true"
        },
        "FEATURE_EMAIL_SMS_FALLBACK": {
          "default": "true"
        },
        "FEATURE_MULTILANGUAGE": {
          "default": "true"
        },
        "FEATURE_RAG_REPLIES": {
          "default": "true"
        },
        "FEATURE_QUOTE_BOT": {
          "description": "Enable Auto Quote Bot for cab/rental (true/false)",
          "default": "false"
        },
        "QUOTE_BOT_CATEGORY": {
          "description": "Quote bot category: cab_rental, tour_operator, or none",
          "default": "none"
        },
        "PLATFORM_BILLING_URL": {
          "description": "Operator license API — payments go to template owner (customers never add RAZORPAY keys)",
          "default": "https://license-server-production-fe55.up.railway.app/api/v1/platform-billing"
        },
        "PLATFORM_BILLING_REGISTER_KEY": {
          "description": "Shared register key from template owner",
          "default": "7e07488a469ffe1f3d01eff7ae1c5cf2"
        }
      }
    },
    {
      "name": "dashboard",
      "root": "dashboard",
      "build": {
        "builder": "DOCKERFILE",
        "dockerfilePath": "Dockerfile"
      },
      "deploy": {
        "healthcheckPath": "/",
        "healthcheckTimeout": 120,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 3
      },
      "networking": {
        "serviceDomains": {
          "<hasDomain>": {}
        }
      },
      "variables": {
        "VITE_API_URL": "https://${{backend.RAILWAY_PUBLIC_DOMAIN}}/api/v1"
      }
    }
  ]
}